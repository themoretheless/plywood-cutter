<div class="num-wrap">
    <button type="button" class="num-btn" @onclick="Decrement">−</button>
    <input type="number" value="@Value" @onchange="OnChange" min="@Min" step="@Step" />
    <button type="button" class="num-btn" @onclick="Increment">+</button>
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Step { get; set; } = 1;

    Task Increment() => ValueChanged.InvokeAsync(Value + Step);
    Task Decrement() => ValueChanged.InvokeAsync(Math.Max(Min, Value - Step));

    Task OnChange(ChangeEventArgs e) =>
        double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v)
            ? ValueChanged.InvokeAsync(v)
            : Task.CompletedTask;
}
