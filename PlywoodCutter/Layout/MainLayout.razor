@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject L10n L
@inject LocalStorageService Store

<div class="theme-toggle-wrap">
    <div class="top-controls">
        <button class="lang-toggle" @onclick="ToggleLang" title="RU / EN">
            @(L.Lang == "ru" ? "RU" : "EN")
        </button>
        <span class="theme-toggle-label">@L["theme"]</span>
        <button class="theme-toggle @(_isDark ? "is-dark" : "is-light")" @onclick="ToggleTheme" title="Toggle theme">
            <span class="toggle-track" @ref="_trackRef">

                <!-- Sun SVG -->
                <span class="toggle-icon toggle-sun">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="#f5a623" stroke-width="2.2" stroke-linecap="round">
                        <circle cx="12" cy="12" r="4" fill="#f5a623" stroke="none" class="sun-core"/>
                        <g class="sun-rays">
                            <line x1="12" y1="2"    x2="12" y2="5"/>
                            <line x1="12" y1="19"   x2="12" y2="22"/>
                            <line x1="2"  y1="12"   x2="5"  y2="12"/>
                            <line x1="19" y1="12"   x2="22" y2="12"/>
                            <line x1="4.93"  y1="4.93"  x2="7.05"  y2="7.05"/>
                            <line x1="16.95" y1="16.95" x2="19.07" y2="19.07"/>
                            <line x1="19.07" y1="4.93"  x2="16.95" y2="7.05"/>
                            <line x1="4.93"  y1="19.07" x2="7.05"  y2="16.95"/>
                        </g>
                    </svg>
                </span>

                <!-- Moon SVG: thin crescent, centered via viewBox crop -->
                <span class="toggle-icon toggle-moon">
                    <svg width="16" height="16" viewBox="3 3 18 18" fill="#ffd700" stroke="none">
                        <path d="M12 3 A6 6 0 0 1 3 12 A9 9 0 1 0 12 3 Z" class="moon-shape"/>
                    </svg>
                </span>

                <span class="toggle-thumb"></span>
            </span>
        </button>
    </div>
</div>

<nav class="page-nav">
    <NavLink class="page-nav-link" href="" Match="NavLinkMatch.All">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        @L["nav.cutting"]
    </NavLink>
    <NavLink class="page-nav-link" href="box">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        </svg>
        @L["nav.box"]
    </NavLink>
    <NavLink class="page-nav-link" href="laser">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <line x1="12" y1="2" x2="12" y2="6"/>
            <line x1="12" y1="18" x2="12" y2="22"/>
            <line x1="4.22" y1="4.22" x2="7.05" y2="7.05"/>
            <line x1="16.95" y1="16.95" x2="19.78" y2="19.78"/>
        </svg>
        @L["nav.laser"]
    </NavLink>
</nav>

<main>
    @Body
</main>

@code {
    bool _isDark = true;
    ElementReference _trackRef;

    protected override void OnInitialized()
    {
        L.OnChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeInterop.init");
            _isDark = theme != "light";

            var lang = await Store.GetAsync("lang");
            if (!string.IsNullOrEmpty(lang))
                L.Lang = lang;

            StateHasChanged();

            if (_isDark)
                await JS.InvokeVoidAsync("starsInterop.start", _trackRef);
        }
    }

    async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("themeInterop.set", _isDark ? "dark" : "light");

        if (_isDark)
            await JS.InvokeVoidAsync("starsInterop.start", _trackRef);
        else
            await JS.InvokeVoidAsync("starsInterop.stop");
    }

    async Task ToggleLang()
    {
        L.Lang = L.Lang == "ru" ? "en" : "ru";
        await Store.SetAsync("lang", L.Lang);
    }

    public void Dispose() => L.OnChanged -= StateHasChanged;
}
